{
    "name": "@plurnk/plurnk-execs-search",
    "version": "0.2.4",
    "description": "Web search runtime executor for plurnk-service's exec scheme — dispatches search/news/images/… runtime tags to a SearXNG instance.",
    "keywords": [
        "plurnk",
        "exec",
        "runtime",
        "executor",
        "search",
        "searxng",
        "web"
    ],
    "homepage": "https://github.com/plurnk/plurnk-execs-search#readme",
    "bugs": {
        "url": "https://github.com/plurnk/plurnk-execs-search/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/plurnk/plurnk-execs-search.git"
    },
    "engines": {
        "node": ">=25"
    },
    "license": "MIT",
    "author": "@wikitopian",
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "plurnk": {
        "kind": "exec",
        "runtimes": [
            {
                "name": "search",
                "glyph": "🔎",
                "example": "EXEC[search]:france population:EXEC"
            },
            {
                "name": "images",
                "glyph": "🖼",
                "example": "EXEC[images]:red panda:EXEC"
            },
            {
                "name": "videos",
                "glyph": "🎬",
                "example": "EXEC[videos]:how to tie a bowline:EXEC"
            },
            {
                "name": "news",
                "glyph": "📰",
                "example": "EXEC[news]:ecb rate decision:EXEC"
            },
            {
                "name": "map",
                "glyph": "🗺",
                "example": "EXEC[map]:eiffel tower:EXEC"
            },
            {
                "name": "music",
                "glyph": "🎵",
                "example": "EXEC[music]:miles davis so what:EXEC"
            },
            {
                "name": "it",
                "glyph": "💻",
                "example": "EXEC[it]:rust borrow checker:EXEC"
            },
            {
                "name": "science",
                "glyph": "🔬",
                "example": "EXEC[science]:crispr off-target effects:EXEC"
            },
            {
                "name": "social",
                "glyph": "💬",
                "example": "EXEC[social]:fediverse migration:EXEC"
            },
            {
                "name": "downloadable",
                "glyph": "📥",
                "example": "EXEC[downloadable]:debian netinst iso:EXEC"
            }
        ]
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/**/*",
        "README.md"
    ],
    "scripts": {
        "test:lint": "tsc --noEmit",
        "test:unit": "node --test \"src/**/*.test.ts\"",
        "test": "npm run test:lint && npm run test:unit",
        "build:dist": "tsc -p tsconfig.build.json",
        "build": "npm run build:dist",
        "prepare": "npm run build"
    },
    "devDependencies": {
        "@types/node": "^25.8.0",
        "typescript": "^6.0.3",
        "@plurnk/plurnk-execs": "0.4.1"
    },
    "peerDependencies": {
        "@plurnk/plurnk-execs": "0.4.1"
    }
}
